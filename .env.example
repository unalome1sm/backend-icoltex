
MONGODB_URI=
MONGODB_DB_NAME=

# Server Configuration
PORT=

# CORS: orígenes del frontend (coma, sin espacios o con espacios si tu parser los recorta).
# Incluye el dominio de Vercel para que fetch desde el navegador funcione con NEXT_PUBLIC_API_URL.
CORS_ORIGINS=http://localhost:3000,https://frontend-icoltex.vercel.app

# Environment
NODE_ENV=development

# API Icoltex (webhook - Basic Auth). Solo la base; los endpoints se definen en config.
ICOLTEX_API_URL=
ICOLTEX_API_USER=
ICOLTEX_API_PASSWORD=

# Webhook Tangara: ternas clase / categoría / color (GET). Requiere Basic Auth (mismas ICOLTEX_API_USER / ICOLTEX_API_PASSWORD). URL opcional.
ICOLTEX_CARACTERISTICAS_WEBHOOK_URL=

# Auth (JWT y sesión)
JWT_SECRET=
JWT_EXPIRES_IN=7d

# SMTP (Nodemailer) para códigos OTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# OTP
AUTH_OTP_TTL_MINUTES=10
AUTH_OTP_RESEND_SECONDS=60
